# ===== BSC RPC =====
# WebSocket RPC for swap event subscription (required，实时流)
BSC_WSS_URL=wss://your-bsc-wss-endpoint
# HTTP RPC，可选，仅 scripts/backfill.ts 历史回补用
# 默认 http://151.123.172.62:81（Bro 自建节点），自己用换成自己的
BSC_HTTP_URL=

# ===== OKX DEX API (price service for native + stables) =====
# Native price (WBNB) is fetched via OKX DEX market price-info
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# ===== Binance =====
# 不需要 API key——使用公共 endpoints:
#   GET https://fapi.binance.com/fapi/v1/exchangeInfo
#   GET https://www.binance.com/bapi/capital/v1/public/capital/getNetworkCoinAll

# ===== Storage (PostgreSQL via Docker) =====
# 生产部署请把 POSTGRES_PASSWORD 改成强密码（openssl rand -hex 16），
# 同时把 DATABASE_URL 里的 `radar` 替换成新密码
POSTGRES_PASSWORD=radar
DATABASE_URL=postgresql://radar:radar@localhost:5434/radar

# ===== Anomaly thresholds =====
# vol_spike 触发: 当前 5min volume > N × 24h 均值
ANOMALY_VOL_SPIKE_RATIO=5
# combo 强信号: vol_spike 同时满足 + fee/TVL 年化 ≥ X%
ANOMALY_FEE_TVL_APR=100
# Detector tick interval (ms)
ANOMALY_DETECT_INTERVAL_MS=30000
# 同 token + 同 rule 冷却 (ms)
ANOMALY_COOLDOWN_MS=300000
# vol_spike 至少需要这么久的 baseline 数据才会触发，避免冷启动假阳
ANOMALY_BASELINE_MIN_COVERAGE_MS=3600000

# ===== Notifier (Phase 4) — 飞书自定义机器人 =====
# 飞书群里：群机器人 → 添加 → 自定义机器人 → 复制 Webhook 地址
NOTIFY_FEISHU_WEBHOOK=
# 可选：创建机器人时勾"签名校验"才需要填这个 secret
NOTIFY_FEISHU_SECRET=
