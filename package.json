{
  "name": "bsc-binance-radar",
  "version": "0.1.0",
  "description": "Monitor anomaly (volume + fee/TVL) of Binance Futures-listed tokens on BSC DEX pools",
  "type": "module",
  "scripts": {
    "start": "bun src/index.ts",
    "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "sync-perpetuals": "bun scripts/sync-perpetuals.ts",
    "test-feishu": "bun scripts/test-feishu.ts"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "grammy": "^1.38.4",
    "pg": "^8.13.1",
    "viem": "2.48.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "@types/pg": "^8.11.10",
    "bun-types": "^1.3.5",
    "typescript": "^5.9.3"
  }
}
